# Remaster — bring your own keys. Everything is optional; with no keys at all
# the app runs fully local (local whisper + your original voice, no AI rewrite,
# click-driven zooms only). Keys can also be entered in the app's Settings tab
# (stored in <data dir>/settings.json) — that takes precedence over this file.

# Speech-to-text (fast cloud transcription; falls back to local faster-whisper)
GROQ_API_KEY=

# Script clean/translate + AI-vision zoom (either or both; Cerebras is tried first)
CEREBRAS_API_KEY=
GEMINI_API_KEY=

# Text-to-speech revoicing (Google Chirp3-HD voices)
GOOGLE_API_KEY=
# ...or a service account instead of an API key:
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# ElevenLabs voices (optional TTS provider)
ELEVENLABS_API_KEY=

# Any OpenAI-compatible endpoint for script rewrite (OpenAI, Ollama, OpenRouter...)
OPENAI_API_KEY=
# OPENAI_BASE_URL=http://localhost:11434/v1

# Where project data lives (default: ./projects inside the repo)
# REMASTER_DATA_DIR=~/remaster-projects
