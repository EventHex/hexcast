# Remaster — bring your own keys. Everything is optional; with no keys at all
# the app runs fully local (local whisper + your original voice, no AI rewrite,
# click-driven zooms only). Keys can also be entered in the app's Settings tab
# (stored in <data dir>/settings.json) — that takes precedence over this file.

# Speech-to-text (fast cloud transcription; falls back to local faster-whisper)
GROQ_API_KEY=

# Script clean/translate + AI-vision zoom (either or both; Cerebras is tried first)
CEREBRAS_API_KEY=
GEMINI_API_KEY=

# Text-to-speech revoicing (Google Chirp3-HD voices)
GOOGLE_API_KEY=
# ...or a service account instead of an API key:
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# ElevenLabs voices (optional TTS provider)
ELEVENLABS_API_KEY=

# Any OpenAI-compatible endpoint for script rewrite (OpenAI, Ollama, OpenRouter...)
OPENAI_API_KEY=
# OPENAI_BASE_URL=http://localhost:11434/v1

# Where project data lives (default: ./projects inside the repo)
# REMASTER_DATA_DIR=~/remaster-projects

# ---- Multi-user (SaaS) mode ----
# The server is multi-user by default: everyone signs up / logs in and each
# account's projects + BYOK keys are isolated. IMPORTANT: in this mode the
# provider keys ABOVE are NOT a shared fallback — leave them blank on a shared
# host (each user adds their own in Settings), or they'd only seed the very
# first account. Set REMASTER_MULTIUSER=0 for a private single-user install
# that uses the keys above.
# REMASTER_MULTIUSER=1
#
# Central control plane (SaaS "model B"): when set, this app becomes a client —
# sign-in/verify/usage go to the remote service (see central/), while all video
# processing stays local. Unset => self-contained local accounts (default).
# REMASTER_AUTH_URL=https://remaster-central-xxxx.run.app
#
# Session-signing secret. Auto-generated + persisted if unset; set it explicitly
# to keep sessions valid across restarts / multiple instances.
# REMASTER_SECRET_KEY=
#
# Optional "Continue with Google" sign-in (needs a Google OAuth app; callback
# https://YOUR-HOST/api/auth/google/callback). Email+password works without it.
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=
