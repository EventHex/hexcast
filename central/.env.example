# Central control plane config

# Session-signing secret (REQUIRED in production). Keep it stable so sessions
# survive restarts / multiple instances. Generate: openssl rand -hex 32
SECRET_KEY=

# Database. Unset -> SQLite file (local dev). For GCP set the Cloud SQL Postgres
# URL (Cloud Run connects via the Cloud SQL connector or a private IP):
# DATABASE_URL=postgresql://USER:PASS@HOST:5432/hexcast
# DATABASE_URL=

# CORS — comma-separated origins allowed to call this API from a browser.
# The desktop app calls server-to-server so this can stay restrictive.
# ALLOW_ORIGINS=*

# Optional Google sign-in (loopback flow for the desktop app).
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=
# DESKTOP_LOOPBACK=http://127.0.0.1:8765/auth/google/done
